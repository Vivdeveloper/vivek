RewriteEngine On
RewriteRule ^sitemap\.xml$ sitemap.php [L]
RewriteRule ^robots\.txt$ robots.php [L]

# Tell Apache to treat these specifically as PHP if needed
<Files sitemap.xml>
    ForceType application/x-httpd-php
</Files>
<Files robots.txt>
    ForceType application/x-httpd-php
</Files>

# ==============================
# Security — Block direct access
# ==============================
RewriteRule ^config/.*$   - [F,L]
RewriteRule ^includes/.*$ - [F,L]

# ==============================
# Clean Permalinks (No router.php)
# ==============================
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d

RewriteCond %{REQUEST_URI} !^/admin/
RewriteCond %{REQUEST_URI} !^/assets/
RewriteCond %{REQUEST_URI} !^/includes/

# Blog listing and archives
RewriteRule ^blog/?$ blog.php [L,QSA]
RewriteRule ^category/([A-Za-z0-9_.-]+)/?$ category.php?slug=$1 [L,QSA]

# Single post (optional pretty URL)
RewriteRule ^post/([A-Za-z0-9_.-]+)/?$ post.php?slug=$1 [L,QSA]

# Search
RewriteRule ^search/?$ search.php [L,QSA]

# Route all other slugs through the router for post/page detection
RewriteRule ^([A-Za-z0-9_.-]+)/?$ router.php?slug=$1 [L,QSA]
RewriteRule ^([A-Za-z0-9_.-]+)/([A-Za-z0-9_.-]+)/?$ router.php?cat=$1&slug=$2 [L,QSA]

# ==============================
# Prevent Directory Listing
# ==============================
Options -Indexes

# ==============================
# Security Headers
# ==============================
<IfModule mod_headers.c>
    Header always set X-Content-Type-Options "nosniff"
    Header always set X-Frame-Options "SAMEORIGIN"
    Header always set X-XSS-Protection "1; mode=block"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>

# ==============================
# Protect Sensitive Files
# ==============================
<FilesMatch "\.(env|md|json|lock|db|sql)$">
    Order allow,deny
    Deny from all
</FilesMatch>

# ==============================
# GZIP Compression
# ==============================
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/css text/javascript application/javascript application/json
</IfModule>

# ==============================
# Browser Cache for Static Assets
# ==============================
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType image/jpeg   "access plus 1 month"
    ExpiresByType image/png    "access plus 1 month"
    ExpiresByType image/gif    "access plus 1 month"
    ExpiresByType image/webp   "access plus 1 month"
    ExpiresByType image/svg+xml "access plus 1 month"
    ExpiresByType text/css     "access plus 1 week"
    ExpiresByType application/javascript "access plus 1 week"
</IfModule>

# Redirect HTTP → HTTPS (uncomment on production)
# RewriteCond %{HTTPS} off
# RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]
